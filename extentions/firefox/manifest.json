{
  "manifest_version": 3,
  "name": "CSynth Ingest (Firefox)",
  "version": "1.0",
  "description": "Captures job listings and sends them to your CSynth vault.",
  "browser_specific_settings": {
    "gecko": {
      "id": "csynth-ingest@ahmedtrooper.com",
      "strict_min_version": "115.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  },
  "icons": {
    "128": "icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
